{
  "name": "Generador QR — OurToolkit",
  "short_name": "QR Generator",
  "description": "Genera códigos QR personalizados al instante: URLs, texto, WiFi, vCard. Gratis, sin registro.",
  "start_url": "/qr/es/",
  "scope": "/qr/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#08080f",
  "theme_color": "#6366f1",
  "lang": "es",
  "categories": [
    "utilities",
    "productivity"
  ],
  "icons": [
    {
      "src": "/qr/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/qr/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Español",
      "url": "/qr/es/"
    },
    {
      "name": "English",
      "url": "/qr/en/"
    },
    {
      "name": "Português",
      "url": "/qr/pt/"
    },
    {
      "name": "Français",
      "url": "/qr/fr/"
    }
  ],
  "share_target": {
    "action": "/qr/es/",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "prefer_related_applications": false
}
